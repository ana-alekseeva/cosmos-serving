# cosmos-serving job secrets/config — copy to `.env` (gitignored) and fill in.
#
# npa does NOT auto-read a .env: it reads secrets from `~/.npa/credentials.yaml` OR from the
# environment. `jobs/with-env.sh` sources this file so npa (and SkyPilot) fetch it automatically:
#     ./jobs/with-env.sh npa workbench cosmos deploy ...
#     ./jobs/with-env.sh sky jobs launch jobs/job1-ablation-matrix.sky.yaml
# (SkyPilot can also load it directly:  sky jobs launch --env-file .env <spec>)
#
# ONLY secrets + Nebius account context live here. Everything else has a home:
#   model params  -> config/experiment.yaml   (MODEL, sampling, dataset shapes)
#   backend        -> job config (sky.yaml envs / --backend)
#   GPU type/preset, subnet -> job config (deploy/sky.yaml) / resolved by npa

# --- Secrets (never commit) --------------------------------------------------------
HF_TOKEN=                         # Hugging Face token — gated Cosmos3-Nano-Policy-DROID download
AWS_ACCESS_KEY_ID=                # Nebius object-storage (S3) key — result uploads (aws s3 cp)
AWS_SECRET_ACCESS_KEY=

# --- Nebius account / project context ----------------------------------------------
PROJECT_ID=                       # Nebius project id
PROJECT_ALIAS=                    # npa workbench project alias (npa workbench cosmos -p <alias>)
TENANT_ID=                        # Nebius tenant id
REGION=eu-north1
REGISTRY_ID=
# SUBNET_ID is resolved by npa (a READY subnet) — do not set it here.

# --- Object storage ----------------------------------------------------------------
AWS_ENDPOINT_URL=https://storage.eu-north1.nebius.cloud
OUTPUT_URI=s3://serverless-challenge/cosmos3-ablation-results/          # Job 2 (latency + traces)
OUTPUT_URI_EVAL=s3://serverless-challenge/robolab-eval-results/subset/  # Job 3 (RoboLab records) — kept separate from OUTPUT_URI

# --- Repo the job clones -----------------------------------------------------------
REPO_URL=https://github.com/ana-alekseeva/cosmos-serving.git
REPO_REF=main
