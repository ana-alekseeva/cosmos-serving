# Cosmos3-Nano-Policy-DROID benchmark image — vLLM-Omni (production) runtime, Job 2/2b.
#
# STOCK STACK: Cosmos3 serving support is upstream in vllm-omni >=0.22 (the checkpoint's
# model_index.json declares Cosmos3OmniDiffusersPipeline; action_mode=policy + domain_name=
# droid_lerobot is the DROID policy path). So the model venv is a PLAIN PyPI venv —
# vllm + vllm-omni pinned in lockstep (deploy/versions.env, verified on H100 2026-07-15) —
# NOT the cosmos-framework uv `vllm` group. That deletes the old image's fragile parts:
# the cu12/cu13 torch flavor re-pinning (framework lock paired a cu13 torch with vllm's
# cu12 binaries) and the torchaudio uninstall (its broken cu12 build crashed transformers).
#
# cosmos_framework is VENDORED BY PYTHONPATH, not installed: the cosmos3 pipeline lazily
# imports three numpy/torch-level modules (data.vfm.action.transforms, model.vfm.diffusion.
# samplers.fm_solvers_unipc, data.vfm.action.pose_utils) for RoboLab policy serving — putting
# the clone on PYTHONPATH satisfies them without dragging in the framework's dependency tree.
#
# Build (context = repo root; wheels are linux/x86_64 -> build --platform linux/amd64):
#   . deploy/versions.env && docker build -f deploy/Dockerfile.vllm \
#     --build-arg VLLM_PIN=$VLLM_PIN --build-arg OMNI_PIN=$OMNI_PIN \
#     -t <registry>/cosmos-droid-vllm:vN .           # bump the tag EVERY push (k8s caches tags)
ARG CUDA_IMAGE=nvidia/cuda:13.0.0-devel-ubuntu24.04
FROM ${CUDA_IMAGE}

ARG COSMOS_FRAMEWORK_REPO=https://github.com/NVIDIA/cosmos-framework
ARG COSMOS_FRAMEWORK_REF=main
ARG VLLM_PIN=0.24.0
ARG OMNI_PIN=0.24.0

ENV DEBIAN_FRONTEND=noninteractive \
    PATH="/opt/omni/.venv/bin:/root/.local/bin:${PATH}" \
    PIP_NO_CACHE_DIR=1 \
    PYTHONUNBUFFERED=1 \
    VENV_HARNESS=/opt/cosmos-serving/.venv \
    VENV_MODEL=/opt/omni/.venv \
    PYTHONPATH=/opt/cosmos-framework

# build-essential + pythonX-dev + ninja: triton and flashinfer JIT-compile kernels at first
# GPU touch (feasibility S2/S3 died on each in turn without them).
RUN apt-get update && apt-get install -y --no-install-recommends \
      git curl ca-certificates ffmpeg build-essential ninja-build python3-dev \
    && rm -rf /var/lib/apt/lists/* \
    && curl -LsSf https://astral.sh/uv/install.sh | sh \
    && uv --version

WORKDIR /opt
COPY . /opt/cosmos-serving
# vllm-omni 0.24's lazy imports use the framework's OLD package layout (…data.vfm.…,
# …model.vfm.…); the repo has since renamed vfm -> generator. Symlink the old names onto
# the new dirs so both dotted paths resolve (no-op if a future ref restores/renames again).
RUN git clone --depth 1 --branch "${COSMOS_FRAMEWORK_REF}" "${COSMOS_FRAMEWORK_REPO}" /opt/cosmos-framework \
    && [ -e /opt/cosmos-framework/cosmos_framework/data/vfm ] \
       || ln -s generator /opt/cosmos-framework/cosmos_framework/data/vfm \
    && [ -e /opt/cosmos-framework/cosmos_framework/model/vfm ] \
       || ln -s generator /opt/cosmos-framework/cosmos_framework/model/vfm

# 1) Harness venv: mock / DROID capture (tfds via the `capture` extra).
RUN cd /opt/cosmos-serving && uv sync --extra capture

# 2) Model venv: stock PyPI vllm + vllm-omni (self-consistent dep tree — torch flavor, CUDA
#    wheels, transformers all resolved together by vllm's own metadata) + this harness editable
#    for the replay client. ninja in-venv so flashinfer's JIT finds it regardless of PATH.
RUN uv venv /opt/omni/.venv --python 3.12 \
    # cosmos-guardrail: Cosmos3's guardrail init hard-requires it (NVIDIA Open Model License).
    # iopath: the vendored cosmos_framework action-transform import chain needs it (pure-python).
    && uv pip install --python /opt/omni/.venv/bin/python \
         "vllm==${VLLM_PIN}" "vllm-omni==${OMNI_PIN}" cosmos-guardrail iopath ninja \
    && uv pip install --python /opt/omni/.venv/bin/python -e /opt/cosmos-serving \
    && py=/opt/omni/.venv/bin/python \
    # import smoke: a missing dep fails the BUILD, not a paid GPU job
    && $py -c 'import vllm, vllm_omni, policy; print("import smoke OK, vllm", vllm.__version__)' \
    && $py -c 'from vllm_omni.diffusion.registry import _DIFFUSION_MODELS; assert "Cosmos3OmniDiffusersPipeline" in _DIFFUSION_MODELS; print("Cosmos3 pipeline registered")' \
    # the three cosmos_framework modules the cosmos3 pipeline lazily imports for RoboLab
    # policy serving — must resolve via PYTHONPATH (numpy/torch-level code only, no install)
    && $py -c 'import cosmos_framework.data.vfm.action.transforms, cosmos_framework.model.vfm.diffusion.samplers.fm_solvers_unipc, cosmos_framework.data.vfm.action.pose_utils; print("vendored cosmos_framework lazy imports OK")'

RUN mkdir -p /local/model /local/replay
WORKDIR /opt/cosmos-serving
CMD ["/bin/bash"]
