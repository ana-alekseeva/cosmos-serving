# Cosmos3-Nano-Policy-DROID benchmark image — vLLM / vLLM-Omni (production) runtime, Job 2/2b.
#
# cosmos-framework declares `vllm` and `cu130` as CONFLICTING uv groups, so this is the SEPARATE
# production image (E ladder / E0,E6 validation); the native P0-P3 ladder runs on deploy/Dockerfile.
# The vllm group ships vllm==0.19.1 + torch==2.10.0 — but this venv must run the PyPI cu128
# torch, NOT the framework's index-mapped cu13x flavor: vllm's binaries are CUDA-12 builds
# (see the torch re-pin below). The cu13 cuBLAS override does NOT apply to this image.
# vLLM-Omni is NOT in the vllm group; it is a separate PyPI package (`vllm-omni`) that provides
# the omni/policy serve path (`vllm serve --omni` — VERIFY the entrypoint on-box).
#
# Build (context = repo root; wheels are linux/x86_64 -> build --platform linux/amd64):
#   docker build -f deploy/Dockerfile.vllm -t <registry>/cosmos-droid-vllm:latest .
ARG CUDA_IMAGE=nvidia/cuda:13.0.0-devel-ubuntu24.04
FROM ${CUDA_IMAGE}

ARG COSMOS_FRAMEWORK_REPO=https://github.com/NVIDIA/cosmos-framework
ARG COSMOS_FRAMEWORK_REF=main

ENV DEBIAN_FRONTEND=noninteractive \
    PATH="/root/.local/bin:${PATH}" \
    PIP_NO_CACHE_DIR=1 \
    PYTHONUNBUFFERED=1 \
    VENV_HARNESS=/opt/cosmos-serving/.venv \
    VENV_MODEL=/opt/cosmos-framework/.venv

RUN apt-get update && apt-get install -y --no-install-recommends \
      git curl ca-certificates ffmpeg build-essential \
    && rm -rf /var/lib/apt/lists/* \
    && curl -LsSf https://astral.sh/uv/install.sh | sh \
    && uv --version

WORKDIR /opt
COPY . /opt/cosmos-serving
RUN git clone --depth 1 --branch "${COSMOS_FRAMEWORK_REF}" "${COSMOS_FRAMEWORK_REPO}" /opt/cosmos-framework

# 1) Harness venv: mock / DROID capture (tfds via the `capture` extra).
RUN cd /opt/cosmos-serving && uv sync --extra capture

# 2) Model venv: the vllm group (vllm==0.19.1) + the PyPI cu128 torch it was compiled against +
#    vllm-omni from PyPI + this harness editable. NO --all-extras: the extras drag in a torchaudio
#    whose ABI mismatches the vllm group's torch (import vllm loads torchaudio opportunistically
#    -> OSError libtorchaudio), and the serving/client path needs none of them. NB: NEVER `uv run`
#    after the pip installs — it auto-syncs back to the lock and removes them (use .venv/bin/python
#    directly).
#    torch flavor is THE trap: vllm 0.19.1's PyPI wheels are CUDA-12 binaries (vllm/_C.abi3.so
#    NEEDs libcudart.so.12), but `[tool.uv.sources]` maps torch to the cu13 pytorch index
#    GLOBALLY, so the sync leaves a cu13-only venv where `import vllm._C` fails on any GPU node —
#    and only there: without a GPU, vllm resolves the CPU platform and never loads _C, so a plain
#    import smoke passes. Re-pin torch to PyPI's ==2.10.0 (the cu128 build): unlike pytorch-index
#    wheels it declares its nvidia-*-cu12 deps, bringing libcudart.so.12 + cuBLAS 12.8.4.1
#    (known-good on H200+r580 — the cu13 13.1.0.3 GEMM bug doesn't apply to this venv anymore).
#    --reinstall-package forces the flavor swap (PEP440: ==2.10.0 is satisfied by 2.10.0+cu130).
#    Do NOT install the cu13 nvidia-cublas/nvidia-cuda-runtime pins here: those are torch
#    2.13+cu130's versions and drag torch up to 2.13.0+cu130 (breaking vllm._C's torch ABI too).
#    torchaudio must be UNINSTALLED, not just unused: transformers>=5 (pulled by vllm-omni)
#    imports it on the `vllm` CLI path guarded only by `except ImportError` — a broken install
#    raises OSError from ctypes and crashes; an absent one is handled cleanly.
RUN cd /opt/cosmos-framework \
    && uv sync --group vllm \
    # vllm-omni PINNED to 0.20.0: omni's own version check wants vllm's major/minor (no 0.19.x
    # omni exists; 0.20 is the closest), and 0.24.0 force-upgrades transformers>=5.5.3 /
    # huggingface-hub>=1.x — way past what the vllm==0.19.1 lock was resolved against.
    # Same resolve as the torch re-pin so uv can't see the cu13 flavor as satisfying anything.
    && uv pip install --index-url https://pypi.org/simple \
         --reinstall-package torch --reinstall-package torchvision \
         "torch==2.10.0" "torchvision==0.25.0" "vllm-omni==0.20.0" \
    && uv pip install -e /opt/cosmos-serving \
    && uv pip uninstall torchaudio \
    && py=/opt/cosmos-framework/.venv/bin/python \
    # import smoke: a missing dep fails the BUILD, not a paid GPU job
    && $py -c 'import vllm, policy; print("import smoke OK, vllm", vllm.__version__)' \
    # NOT `vllm --help`: building the serve subparser instantiates DeviceConfig, which needs a
    # GPU to infer the device — impossible in docker build. Importing the CLI module covers the
    # same import chain (it's what caught the broken torchaudio); run `vllm --help` on-box.
    && $py -c 'import vllm.entrypoints.cli.main; print("vllm CLI import OK")' \
    && $py -c 'import torch; assert torch.version.cuda == "12.8", torch.version.cuda; print("torch", torch.__version__, "toolkit", torch.version.cuda)' \
    # Linkage smoke: dlopen vllm's compiled extensions with the CUDA driver stub standing in for
    # libcuda.so.1 — the ONE check that catches a CUDA-flavor mismatch (libcudart.so.12 vs .13)
    # at build time instead of in a paid GPU job's preflight.
    && ln -sf /usr/local/cuda/lib64/stubs/libcuda.so /tmp/libcuda.so.1 \
    && LD_LIBRARY_PATH=/tmp:/usr/local/cuda/lib64/stubs $py -c 'import torch, ctypes, sysconfig; sp = sysconfig.get_paths()["purelib"]; [ctypes.CDLL(f"{sp}/vllm/{so}") for so in ("_C.abi3.so", "_moe_C.abi3.so")]; print("vllm _C dlopen OK (cu12 runtime linked)")'

RUN mkdir -p /local/model /local/replay
WORKDIR /opt/cosmos-serving
CMD ["/bin/bash"]
