# Cosmos3-Nano-Policy-DROID benchmark image — vLLM / vLLM-Omni (production) runtime, Job 2/2b.
#
# cosmos-framework declares `vllm` and `cu130` as CONFLICTING uv groups, so this is the SEPARATE
# production image (E ladder / E0,E6 validation); the native P0-P3 ladder runs on deploy/Dockerfile.
# The vllm group ships vllm==0.19.1 + torch==2.10.0 — which resolves to a cu13x build (torch is
# source-mapped to the pytorch index globally), so the cu13 cuBLAS override DOES apply here.
# vLLM-Omni is NOT in the vllm group; it is a separate PyPI package (`vllm-omni`) that provides
# the omni/policy serve path (`vllm serve --omni` — VERIFY the entrypoint on-box).
#
# Build (context = repo root; wheels are linux/x86_64 -> build --platform linux/amd64):
#   docker build -f deploy/Dockerfile.vllm -t <registry>/cosmos-droid-vllm:latest .
ARG CUDA_IMAGE=nvidia/cuda:13.0.0-devel-ubuntu24.04
FROM ${CUDA_IMAGE}

ARG COSMOS_FRAMEWORK_REPO=https://github.com/NVIDIA/cosmos-framework
ARG COSMOS_FRAMEWORK_REF=main

ENV DEBIAN_FRONTEND=noninteractive \
    PATH="/root/.local/bin:${PATH}" \
    PIP_NO_CACHE_DIR=1 \
    PYTHONUNBUFFERED=1 \
    VENV_HARNESS=/opt/cosmos-serving/.venv \
    VENV_MODEL=/opt/cosmos-framework/.venv

RUN apt-get update && apt-get install -y --no-install-recommends \
      git curl ca-certificates ffmpeg build-essential \
    && rm -rf /var/lib/apt/lists/* \
    && curl -LsSf https://astral.sh/uv/install.sh | sh \
    && uv --version

WORKDIR /opt
COPY . /opt/cosmos-serving
RUN git clone --depth 1 --branch "${COSMOS_FRAMEWORK_REF}" "${COSMOS_FRAMEWORK_REPO}" /opt/cosmos-framework

# 1) Harness venv: mock / DROID capture (tfds via the `capture` extra).
RUN cd /opt/cosmos-serving && uv sync --extra capture

# 2) Model venv: the vllm group (vllm==0.19.1 + torch 2.10.0 cu128) + vllm-omni from PyPI + this
#    harness editable. NO --all-extras: the extras drag in a torchaudio whose ABI mismatches the
#    vllm group's torch (import vllm loads torchaudio opportunistically -> OSError libtorchaudio),
#    and the serving/client path needs none of them. NB: NEVER `uv run` after the pip installs —
#    it auto-syncs back to the lock and removes them (use .venv/bin/python directly).
#    torchaudio must be UNINSTALLED, not just unused: the vllm group's lock ships a cu12-linked
#    build (needs libcudart.so.12), and transformers>=5 (pulled by vllm-omni) imports torchaudio
#    on the `vllm` CLI path guarded only by `except ImportError` — a broken install raises OSError
#    from ctypes and crashes; an absent one is handled cleanly.
#    NB: `[tool.uv.sources]` maps torch to the pytorch index GLOBALLY, so even this group's
#    `torch==2.10.0` resolves to a cu13x flavor (that is WHY no libcudart.so.12 exists here) —
#    which means the H200+r580 cuBLAS bug applies to THIS venv too: override the broken
#    13.1.0.3 pin with 13.1.1.3 exactly like the native image.
RUN cd /opt/cosmos-framework \
    && uv sync --group vllm \
    # vllm-omni PINNED to 0.20.0: omni's own version check wants vllm's major/minor (no 0.19.x
    # omni exists; 0.20 is the closest), and 0.24.0 force-upgrades transformers>=5.5.3 /
    # huggingface-hub>=1.x — way past what the vllm==0.19.1 lock was resolved against.
    && uv pip install "vllm-omni==0.20.0" \
    && uv pip install -e /opt/cosmos-serving \
    && uv pip uninstall torchaudio \
    && uv pip install "nvidia-cublas==13.1.1.3" "nvidia-cuda-runtime==13.0.96" \
    && py=/opt/cosmos-framework/.venv/bin/python \
    # import smoke: a missing dep fails the BUILD, not a paid GPU job
    && $py -c 'import vllm, policy; print("import smoke OK, vllm", vllm.__version__)' \
    # NOT `vllm --help`: building the serve subparser instantiates DeviceConfig, which needs a
    # GPU to infer the device — impossible in docker build. Importing the CLI module covers the
    # same import chain (it's what caught the broken torchaudio); run `vllm --help` on-box.
    && $py -c 'import vllm.entrypoints.cli.main; print("vllm CLI import OK")' \
    && $py -c 'import torch; print("torch", torch.__version__, "toolkit", torch.version.cuda)'

RUN mkdir -p /local/model /local/replay
WORKDIR /opt/cosmos-serving
CMD ["/bin/bash"]
